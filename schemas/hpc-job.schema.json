{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "HPCJob",
  "description": "SimFlow HPC job configuration schema",
  "type": "object",
  "required": ["job_name", "scheduler", "executable"],
  "properties": {
    "job_name": {
      "type": "string",
      "description": "Job name for scheduler"
    },
    "scheduler": {
      "type": "string",
      "enum": ["slurm", "pbs", "lsf", "local"],
      "description": "Job scheduler type"
    },
    "executable": {
      "type": "string",
      "description": "Command to execute (e.g., mpirun vasp_std)"
    },
    "nodes": {
      "type": "integer",
      "minimum": 1,
      "default": 1,
      "description": "Number of compute nodes"
    },
    "ntasks": {
      "type": "integer",
      "minimum": 1,
      "default": 1,
      "description": "Number of MPI tasks"
    },
    "cpus_per_task": {
      "type": "integer",
      "minimum": 1,
      "default": 1
    },
    "walltime": {
      "type": "string",
      "pattern": "^[0-9]{2}:[0-9]{2}:[0-9]{2}$",
      "default": "01:00:00",
      "description": "Maximum wall time (HH:MM:SS)"
    },
    "partition": {
      "type": "string",
      "description": "Scheduler partition/queue"
    },
    "account": {
      "type": ["string", "null"],
      "description": "Billing account"
    },
    "memory": {
      "type": ["string", "null"],
      "description": "Memory per node (e.g., '16GB')"
    },
    "modules": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Environment modules to load"
    },
    "pre_commands": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Commands before executable"
    },
    "mpi_launcher": {
      "type": "string",
      "enum": ["mpirun", "mpiexec", "srun", "ibrun"],
      "default": "mpirun"
    },
    "output_file": {
      "type": "string",
      "default": "job.out"
    },
    "error_file": {
      "type": "string",
      "default": "job.err"
    },
    "dry_run": {
      "type": "boolean",
      "default": true,
      "description": "Generate script without submitting"
    }
  }
}
