{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Artifact",
  "description": "Artifact metadata and lineage",
  "type": "object",
  "required": ["artifact_id", "name", "type", "version", "stage", "lineage", "metadata", "created_at"],
  "properties": {
    "artifact_id": {
      "type": "string",
      "pattern": "^art_[a-z0-9]{8}$"
    },
    "name": {
      "type": "string"
    },
    "type": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^v\\d+\\.\\d+\\.\\d+$"
    },
    "stage": {
      "type": "string"
    },
    "path": {
      "type": ["string", "null"]
    },
    "lineage": {
      "type": "object",
      "required": ["parent_artifacts", "parameters", "software"],
      "properties": {
        "parent_artifacts": {
          "type": "array",
          "items": { "type": "string" }
        },
        "parameters": {
          "type": "object"
        },
        "software": {
          "type": ["string", "null"]
        }
      },
      "additionalProperties": true
    },
    "metadata": {
      "type": "object"
    },
    "checksum": {
      "type": ["string", "null"]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": true
}
