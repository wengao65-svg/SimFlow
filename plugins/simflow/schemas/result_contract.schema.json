{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SimFlow Result Contract",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "schema_version": {
      "const": "simflow.result.v1"
    },
    "role": {
      "type": "string",
      "enum": ["helper", "stage_runner", "state_admin"]
    },
    "activity": {
      "type": "string"
    },
    "legacy_status": {},
    "stage": {
      "type": "string"
    },
    "outcome": {
      "type": "string",
      "enum": ["success", "warning", "waiting", "blocked", "error", "skipped"]
    },
    "reason_code": {
      "type": "string"
    },
    "state_effect": {
      "type": "string",
      "enum": ["none", "record_only", "stage_transition", "checkpoint_admin"]
    }
  },
  "required": ["schema_version", "role", "activity", "legacy_status", "outcome", "state_effect"]
}
