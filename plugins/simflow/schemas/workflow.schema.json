{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WorkflowDefinition",
  "description": "Open SimFlow workflow definition schema. Workflows describe stage intent and optional recipes; they are not fixed DFT/AIMD/MD executor DAGs.",
  "type": "object",
  "required": ["stages"],
  "anyOf": [
    {"required": ["name"]},
    {"required": ["workflow_name"]}
  ],
  "properties": {
    "name": {
      "type": "string",
      "description": "Workflow or recipe identifier"
    },
    "workflow_name": {
      "type": "string",
      "description": "Backward-compatible workflow identifier"
    },
    "workflow_type": {
      "type": "string",
      "description": "Optional open workflow type or tag. This is not limited to DFT/AIMD/MD."
    },
    "recipe": {
      "type": "string",
      "description": "Optional recipe name such as dft, aimd, classical_md, phonon, neb, or custom"
    },
    "tags": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Open workflow tags"
    },
    "software": {
      "oneOf": [
        {"type": "string"},
        {
          "type": "array",
          "items": {"type": "string"}
        }
      ],
      "description": "Optional open software name or names"
    },
    "description": {
      "type": "string",
      "description": "Human-readable workflow description"
    },
    "stages": {
      "type": "array",
      "items": {
        "oneOf": [
          {"type": "string"},
          {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": {"type": "string"},
              "id": {"type": "string"},
              "required": {"type": "boolean", "default": true},
              "depends_on": {
                "type": "array",
                "items": {"type": "string"}
              },
              "intent": {"type": "string"},
              "handoff_notes": {
                "type": "array",
                "items": {"type": "string"}
              }
            },
            "additionalProperties": true
          }
        ]
      },
      "description": "Ordered or suggested list of research stages"
    },
    "stage_dependencies": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {"type": "string"}
      },
      "description": "Backward-compatible dependency map"
    },
    "entry_point": {
      "type": "string",
      "description": "Optional first suggested stage"
    },
    "entry_points": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Optional independent entry stages"
    },
    "default_entry": {
      "type": "string",
      "description": "Backward-compatible default entry stage"
    },
    "exit_points": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Optional terminal stages"
    },
    "gates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "type"],
        "properties": {
          "name": {"type": "string"},
          "stage": {"type": "string"},
          "type": {"type": "string"}
        },
        "additionalProperties": true
      },
      "description": "Gates applied during workflow execution"
    },
    "policies": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Policy names from workflow/policies/"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
