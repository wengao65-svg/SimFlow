{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "VerificationReport",
  "description": "Verification report persisted in verification.json",
  "type": "object",
  "required": [
    "stage",
    "workflow_id",
    "status",
    "generated_at",
    "completed_at",
    "checks",
    "warnings",
    "failures",
    "source_artifact_ids"
  ],
  "properties": {
    "stage": {
      "type": "string"
    },
    "workflow_id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["pass", "warning", "fail", "pending"]
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "completed_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "status", "message", "details", "checked_at"],
        "properties": {
          "name": { "type": "string" },
          "status": { "type": "string", "enum": ["pass", "warning", "fail", "pending"] },
          "message": { "type": "string" },
          "details": { "type": "object" },
          "checked_at": { "type": "string", "format": "date-time" }
        },
        "additionalProperties": true
      }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "failures": {
      "type": "array",
      "items": { "type": "string" }
    },
    "source_artifact_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "output_file": {
      "type": "string"
    },
    "markdown_file": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
