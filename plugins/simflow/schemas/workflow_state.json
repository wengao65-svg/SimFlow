{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WorkflowState",
  "description": "SimFlow workflow state schema",
  "type": "object",
  "required": ["workflow_id", "workflow_type", "current_stage", "status", "created_at", "updated_at"],
  "properties": {
    "workflow_id": {
      "type": "string",
      "pattern": "^wf_[a-z0-9]{8}$"
    },
    "workflow_type": {
      "type": "string"
    },
    "current_stage": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["initialized", "in_progress", "paused", "completed", "failed"]
    },
    "plan": {
      "type": ["string", "null"]
    },
    "entry_point": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": true
}
