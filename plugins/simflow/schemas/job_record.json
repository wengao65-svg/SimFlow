{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "JobRecord",
  "description": "Recorded computation job submission state",
  "type": "object",
  "required": ["job_id", "workflow_id", "stage", "status", "dry_run", "created_at"],
  "properties": {
    "job_id": {
      "type": "string"
    },
    "workflow_id": {
      "type": "string"
    },
    "stage": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["prepared", "dry_run", "submitted", "running", "completed", "failed", "cancelled"]
    },
    "dry_run": {
      "type": "boolean"
    },
    "scheduler": {
      "type": "string"
    },
    "script_path": {
      "type": ["string", "null"]
    },
    "gate_decision_id": {
      "type": ["string", "null"]
    },
    "dry_run_evidence": {
      "type": ["string", "null"]
    },
    "script_hash": {
      "type": ["string", "null"]
    },
    "input_artifact_hash": {
      "type": ["string", "null"]
    },
    "submitted_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "completed_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "submit_result": {
      "type": "object"
    },
    "execution_truth": {
      "type": "object"
    },
    "path": {
      "type": "string"
    },
    "artifact_id": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
