{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "StageState",
  "description": "Per-stage state tracking",
  "type": "object",
  "required": [
    "stage_name",
    "status",
    "agent",
    "inputs",
    "outputs",
    "checkpoint_id",
    "error_message",
    "started_at",
    "completed_at"
  ],
  "properties": {
    "stage_name": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["pending", "in_progress", "waiting", "completed", "failed", "skipped"]
    },
    "agent": {
      "type": ["string", "null"]
    },
    "inputs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "outputs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "checkpoint_id": {
      "type": ["string", "null"]
    },
    "error_message": {
      "type": ["string", "null"]
    },
    "started_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "completed_at": {
      "type": ["string", "null"],
      "format": "date-time"
    }
  },
  "additionalProperties": true
}
