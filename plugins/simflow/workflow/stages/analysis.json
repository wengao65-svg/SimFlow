{
  "name": "analysis",
  "description": "结果分析阶段：解析 VASP/CP2K 输出并生成 canonical analysis report 供可视化消费",
  "canonical_stage": "analysis_visualization",
  "legacy_alias": true,
  "intent": "Analyze available simulation outputs or user-provided data with scripts, inputs, outputs, and conclusions traceable to artifacts.",
  "acceptable_inputs": ["simulation outputs", "user-provided data", "analysis script", "calculation manifest", "prior checkpoint"],
  "evidence_outputs": ["analysis_script", "analysis_inputs", "analysis_outputs", "analysis_environment", "claim_evidence_map"],
  "recommended_skills": ["simflow-analysis-visualization", "simflow-analysis", "optional parser helper"],
  "suggested_checks": ["input provenance", "script recorded", "environment recorded", "statistical or convergence caveats", "claim traceability"],
  "approval_triggers": ["licensed_or_proprietary_file_handling", "destructive_file_operation"],
  "handoff_notes": ["Record which data were analyzed, which script or helper was used, and which conclusions are supported."],
  "risk_notes": ["Do not force built-in parsers when a recorded custom script is more appropriate."],
  "default_agent": "data_analyst",
  "default_skill": "simflow-analysis",
  "required_inputs": ["compute_plan.json"],
  "optional_inputs": ["compute_output", "analysis_goals"],
  "expected_outputs": ["analysis_report.json", "analysis_report.md"],
  "artifact_types": ["analysis_report", "analysis_markdown"],
  "validators": ["output_completeness", "convergence_check", "trajectory_integrity", "statistical_significance"],
  "approval_gates": ["convergence_failure", "unexpected_results"],
  "checkpoint_policy": "on_completion",
  "recovery_policy": "restart"
}
