{
  "name": "compute",
  "description": "计算准备阶段：默认生成 dry-run compute plan 与 HPC 作业脚本，真实提交仍需审批门",
  "canonical_stage": "computation",
  "legacy_alias": true,
  "intent": "Prepare, validate, optionally run, and record computational simulation jobs with dry-run-first safety gates.",
  "acceptable_inputs": ["user-provided input files", "generated input files", "model artifacts", "calculation plan", "previous checkpoint"],
  "evidence_outputs": ["calculation_manifest", "input_files", "input_validation_report", "dry_run_report", "resource_estimate", "job_record_if_submitted"],
  "recommended_skills": ["simflow-computation", "simflow-compute", "optional engine-specific helper"],
  "suggested_checks": ["input completeness", "resource reasonableness", "software command documented", "environment documented", "output hashes recorded"],
  "approval_triggers": ["real_hpc_submit", "remote_execution", "local_job_submit", "destructive_file_operation", "licensed_or_proprietary_file_handling"],
  "handoff_notes": ["Record what was run, where it was run, with which inputs, and whether outputs are complete."],
  "risk_notes": ["Do not submit real jobs without approval and do not record unfinished jobs as completed."],
  "default_agent": "executor",
  "default_skill": "simflow-compute",
  "required_inputs": ["input_manifest.json"],
  "optional_inputs": ["hpc_config"],
  "expected_outputs": ["compute_plan.json", "job_script.sh", "dry_run_report.json"],
  "artifact_types": ["compute_plan", "job_script", "dry_run_report"],
  "validators": ["dry_run_pass", "resource_reasonableness", "input_completeness", "script_syntax"],
  "approval_gates": ["hpc_submit"],
  "checkpoint_policy": "on_submit_and_completion",
  "recovery_policy": "from_checkpoint"
}
