{
  "name": "literature",
  "description": "文献调研阶段：检索、筛选、元数据整理、引用 artifact 生成",
  "canonical_stage": "literature_review",
  "legacy_alias": true,
  "intent": "Discover, screen, and summarize literature while preserving source, query, screening, and citation traceability.",
  "acceptable_inputs": ["research goal", "user-provided PDFs", "search queries", "seed citations", "prior checkpoint"],
  "evidence_outputs": ["search_log", "paper_notes", "screening_record", "citation_map", "review_summary"],
  "recommended_skills": ["simflow-literature-review", "simflow-literature"],
  "suggested_checks": ["source traceability", "query traceability", "screening criteria documented", "citation verification", "unavailable full text marked"],
  "approval_triggers": [],
  "handoff_notes": ["Record searched sources, search strings, inclusion criteria, inaccessible papers, and interpretation boundaries."],
  "risk_notes": ["Do not fabricate citations, metadata, direct quotes, or paper conclusions."],
  "default_agent": "literature_reviewer",
  "default_skill": "simflow-literature",
  "required_inputs": ["research_keywords"],
  "optional_inputs": ["time_range", "database_preference", "language_preference"],
  "expected_outputs": ["literature_matrix.json", "references.bib", "screening_report.md"],
  "artifact_types": ["literature_matrix", "references", "screening_report"],
  "validators": ["citation_completeness", "deduplication", "coverage_check"],
  "approval_gates": [],
  "checkpoint_policy": "on_completion",
  "recovery_policy": "restart"
}
