{
  "name": "no_credential_storage",
  "description": "禁止凭据存储策略：不允许在仓库、artifact 或日志中存储凭据",
  "scope": "all_stages",
  "rules": [
    {
      "condition": "file_written",
      "action": "scan_for_credentials",
      "parameters": { "patterns": ["password", "token", "api_key", "secret"] }
    },
    {
      "condition": "credential_detected",
      "action": "block_and_report",
      "parameters": { "severity": "critical" }
    }
  ]
}
