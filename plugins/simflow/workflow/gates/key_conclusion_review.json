{
  "name": "key_conclusion_review",
  "description": "关键结论审阅审批门：关键结论需要人工审阅时触发",
  "type": "approval",
  "conditions": [
    {
      "id": "conclusions_written",
      "evidence": "writing/claim_evidence_map.json",
      "path": "$.status",
      "op": "in",
      "value": ["pass", "warning"]
    },
    {
      "id": "evidence_traceable",
      "evidence": "writing/claim_evidence_map.json",
      "path": "$.untraceable_claims",
      "op": "length_eq",
      "value": 0
    }
  ],
  "actions_on_approve": ["accept_conclusions"],
  "actions_on_reject": ["revise_conclusions", "request_additional_analysis"],
  "auto_approve": false,
  "timeout_minutes": 60
}
