{
  "name": "resource_exceeds_budget",
  "description": "资源超预算审批门：资源估算超出合理范围时触发",
  "type": "approval",
  "conditions": [
    {
      "id": "resource_estimate_available",
      "evidence": "proposal/resource_estimate.json",
      "path": "$.status",
      "op": "in",
      "value": ["pass", "warning", "exceeds_budget"]
    },
    {
      "id": "budget_threshold_defined",
      "evidence": "proposal/resource_estimate.json",
      "path": "$.budget_threshold_defined",
      "op": "eq",
      "value": true
    }
  ],
  "thresholds": {
    "cpu_hours": 10000,
    "memory_gb": 500,
    "storage_gb": 1000
  },
  "actions_on_approve": ["proceed_to_modeling"],
  "actions_on_reject": ["suggest_optimization", "revise_parameters"],
  "auto_approve": false,
  "timeout_minutes": 30
}
