{
  "name": "abnormal_optimization",
  "description": "异常优化审批门：结构优化结果异常时触发",
  "type": "approval",
  "conditions": [
    {
      "id": "optimization_completed",
      "evidence": "modeling/optimization_report.json",
      "path": "$.status",
      "op": "in",
      "value": ["pass", "warning"]
    },
    {
      "id": "structure_validated",
      "evidence": "modeling/structure_validation.json",
      "path": "$.status",
      "op": "in",
      "value": ["pass", "warning"]
    }
  ],
  "actions_on_approve": ["accept_structure", "record_modeling_decision"],
  "actions_on_reject": ["suggest_remodeling", "iterate_to_modeling"],
  "auto_approve": false,
  "timeout_minutes": 30
}
