{
  "name": "md_dry_run",
  "description": "Classical MD recipe dry-run example: Cu nanoparticle MD",
  "recipe": "classical_md",
  "software": "lammps",
  "dry_run": true,
  "stages": [
    {
      "name": "proposal",
      "inputs": {
        "research_goal": "MD simulation of Cu nanoparticle melting",
        "system_info": "Cu nanoparticle, 10000 atoms, EAM potential"
      },
      "evidence_outputs": ["proposal", "parameter_rationale", "resource_estimate"]
    },
    {
      "name": "modeling",
      "inputs": {
        "proposal": "proposal.md",
        "structure": "Cu FCC nanoparticle, 5nm diameter"
      },
      "evidence_outputs": ["structure_files", "structure_manifest", "validation_report"]
    },
    {
      "name": "computation",
      "activity": "input_generation",
      "inputs": {
        "model": "data.cu_np",
        "parameters": "parameter_table.json",
        "software": "lammps"
      },
      "evidence_outputs": ["input_files", "calculation_manifest", "input_validation_report"]
    },
    {
      "name": "computation",
      "activity": "dry_run",
      "inputs": {
        "manifest": "input_manifest.json"
      },
      "evidence_outputs": ["job_script", "dry_run_report", "resource_estimate"],
      "dry_run_only": true
    }
  ]
}
