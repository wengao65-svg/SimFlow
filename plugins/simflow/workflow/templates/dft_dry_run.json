{
  "name": "dft_dry_run",
  "description": "DFT recipe dry-run example: Si bulk structure optimization",
  "recipe": "dft",
  "software": "vasp",
  "dry_run": true,
  "stages": [
    {
      "name": "proposal",
      "inputs": {
        "research_goal": "Si bulk structure optimization with PBE functional",
        "system_info": "Si, Fd-3m, a=5.43A"
      },
      "evidence_outputs": ["proposal", "parameter_rationale", "resource_estimate"]
    },
    {
      "name": "modeling",
      "inputs": {
        "proposal": "proposal.md",
        "structure": "conventional cell of Si"
      },
      "evidence_outputs": ["structure_files", "structure_manifest", "validation_report"]
    },
    {
      "name": "computation",
      "activity": "input_generation",
      "inputs": {
        "model": "POSCAR",
        "parameters": "parameter_table.json",
        "software": "vasp"
      },
      "evidence_outputs": ["input_files", "calculation_manifest", "input_validation_report"]
    },
    {
      "name": "computation",
      "activity": "dry_run",
      "inputs": {
        "manifest": "input_manifest.json"
      },
      "evidence_outputs": ["job_script", "dry_run_report", "resource_estimate"],
      "dry_run_only": true
    }
  ]
}
