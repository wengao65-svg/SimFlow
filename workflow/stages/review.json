{
  "name": "review",
  "description": "综述分析阶段：整合文献、提炼趋势、识别研究空白",
  "canonical_stage": "literature_review",
  "legacy_alias": true,
  "intent": "Review prior evidence, compare findings, and identify research gaps without inventing unsupported conclusions.",
  "acceptable_inputs": ["literature notes", "citation map", "review matrix", "user-provided papers", "prior checkpoint"],
  "evidence_outputs": ["review_summary", "gap_analysis", "claim_to_citation_map"],
  "recommended_skills": ["simflow-literature-review", "simflow-review"],
  "suggested_checks": ["citation consistency", "claim support", "conflicting evidence surfaced", "method comparison documented"],
  "approval_triggers": [],
  "handoff_notes": ["Separate direct source evidence from agent interpretation and mark uncertain gaps explicitly."],
  "risk_notes": ["Do not overstate literature gaps or omit contradictory evidence."],
  "default_agent": "synthesizer",
  "default_skill": "simflow-review",
  "required_inputs": ["literature_matrix.json", "references.bib"],
  "optional_inputs": [],
  "expected_outputs": ["review.md", "gap_analysis.md"],
  "artifact_types": ["review", "gap_analysis"],
  "validators": ["topic_coverage", "gap_evidence", "citation_consistency"],
  "approval_gates": [],
  "checkpoint_policy": "on_completion",
  "recovery_policy": "restart"
}
