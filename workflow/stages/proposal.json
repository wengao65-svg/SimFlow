{
  "name": "proposal",
  "description": "方案设计阶段：设计 DFT/AIMD/MD 计算方案、参数、对照组、资源预算",
  "intent": "Turn the research goal and evidence into a computational study proposal with assumptions, risks, resource needs, and acceptance criteria.",
  "acceptable_inputs": ["research goal", "literature review", "user constraints", "available structures", "software/resource preferences", "prior checkpoint"],
  "evidence_outputs": ["proposal", "calculation_plan", "parameter_rationale", "resource_estimate", "risk_register"],
  "recommended_skills": ["simflow-proposal"],
  "suggested_checks": ["goal clarity", "parameter rationale", "resource reasonableness", "control or comparison design", "known risks listed"],
  "approval_triggers": ["large_resource_commitment", "licensed_or_proprietary_file_handling"],
  "handoff_notes": ["Record selected assumptions, rejected alternatives, required inputs, resource estimate, and user constraints."],
  "risk_notes": ["Do not imply the proposal proves results before computation or analysis artifacts exist."],
  "default_agent": "strategist",
  "default_skill": "simflow-proposal",
  "required_inputs": ["research_goal"],
  "optional_inputs": ["gap_analysis.md", "system_info"],
  "expected_outputs": ["proposal.md", "parameter_table.json", "resource_estimate.json"],
  "artifact_types": ["proposal", "parameter_table", "resource_estimate"],
  "validators": ["goal_clarity", "parameter_rationality", "resource_reasonableness", "control_group_completeness"],
  "approval_gates": ["resource_exceeds_budget"],
  "checkpoint_policy": "on_completion",
  "recovery_policy": "restart"
}
