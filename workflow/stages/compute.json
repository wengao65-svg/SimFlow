{
  "name": "compute",
  "description": "计算准备阶段：默认生成 dry-run compute plan 与 HPC 作业脚本，真实提交仍需审批门",
  "default_agent": "executor",
  "default_skill": "simflow-compute",
  "required_inputs": ["input_manifest.json"],
  "optional_inputs": ["hpc_config"],
  "expected_outputs": ["compute_plan.json", "job_script.sh", "dry_run_report.json"],
  "artifact_types": ["compute_plan", "job_script", "dry_run_report"],
  "validators": ["dry_run_pass", "resource_reasonableness", "input_completeness", "script_syntax"],
  "approval_gates": ["hpc_submit"],
  "checkpoint_policy": "on_submit_and_completion",
  "recovery_policy": "from_checkpoint"
}
