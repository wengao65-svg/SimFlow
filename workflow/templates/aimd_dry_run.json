{
  "name": "aimd_dry_run",
  "description": "AIMD recipe dry-run example: liquid water AIMD",
  "recipe": "aimd",
  "software": "vasp",
  "dry_run": true,
  "stages": [
    {
      "name": "proposal",
      "inputs": {
        "research_goal": "AIMD simulation of liquid water at 300K",
        "system_info": "64 H2O molecules, NVT ensemble"
      },
      "evidence_outputs": ["proposal", "parameter_rationale", "resource_estimate"]
    },
    {
      "name": "modeling",
      "inputs": {
        "proposal": "proposal.md",
        "structure": "64 H2O cubic box, 12.4A"
      },
      "evidence_outputs": ["structure_files", "structure_manifest", "validation_report"]
    },
    {
      "name": "computation",
      "activity": "input_generation",
      "inputs": {
        "model": "POSCAR",
        "parameters": "parameter_table.json",
        "software": "vasp"
      },
      "evidence_outputs": ["input_files", "calculation_manifest", "input_validation_report"]
    },
    {
      "name": "computation",
      "activity": "dry_run",
      "inputs": {
        "manifest": "input_manifest.json"
      },
      "evidence_outputs": ["job_script", "dry_run_report", "resource_estimate"],
      "dry_run_only": true
    }
  ]
}
